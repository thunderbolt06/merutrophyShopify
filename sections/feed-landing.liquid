{%- comment -%}
  Feed Landing — reusable programmatic-SEO / GEO-AEO landing section for Meru Trophy.
  One section type powers all /pages/* "feed" landing pages. All content is supplied
  per-page through the template JSON settings + blocks.

  Styled to match the Meru Trophy home page: Assistant font (inherited), the theme's
  native .button component (square, flat), solid cards with a 1px border and a soft
  gold hover shadow, gold used only as an accent (em-gradient headings, number badges,
  icons, thin rules). Mirrors sections/howto-order-compact.liquid + clients-marquee.

  Blocks: quick_answer, rich_text, feature, stat, price_row, step, faq, cta_band, related_collection
{%- endcomment -%}

{%- liquid
  assign wa_number = '917892207252'
  assign phone_display = '+91 78922 07252'
  assign phone_tel = '+917892207252'
  assign phone2_display = '+91 94801 50888'
  assign phone2_tel = '+919480150888'
  assign email = 'merutrophy@gmail.com'

  assign primary_url = section.settings.primary_cta_url
  if primary_url == blank
    assign primary_url = 'https://wa.me/' | append: wa_number
  endif

  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign price_blocks = section.blocks | where: 'type', 'price_row'
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign faq_blocks = section.blocks | where: 'type', 'faq'
-%}

{%- comment -%} Product cards need the theme's base card styles, which aren't loaded globally. {%- endcomment -%}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .feed-ld-{{ section.id }} { --feed-gold: #d4a017; --feed-gold-2: #f5b400; }
  .feed-ld-{{ section.id }} .feed-pad {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .feed-ld-{{ section.id }} .feed-pad {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .feed-ld-{{ section.id }} em {
    font-style: normal;
    background: linear-gradient(135deg, var(--feed-gold), var(--feed-gold-2));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }

  /* breadcrumb */
  .feed-breadcrumb { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.6); margin-bottom: 2rem; }
  .feed-breadcrumb a { color: inherit; text-decoration: none; }
  .feed-breadcrumb a:hover { text-decoration: underline; }

  /* shared header pieces (match howto-order-compact) */
  .feed-eyebrow { display: inline-block; font-size: 1.2rem; letter-spacing: 0.3rem; text-transform: uppercase; color: rgba(var(--color-foreground), 0.6); margin-bottom: 0.8rem; }
  .feed-hero h1 { margin: 0 0 1.2rem; line-height: 1.12; font-size: clamp(2.8rem, 4.6vw, 4.2rem); }
  .feed-sub { font-size: 1.6rem; line-height: 1.6; color: rgba(var(--color-foreground), 0.72); margin: 0 0 2rem; max-width: 60rem; }
  .feed-actions { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* hero */
  .feed-herogrid { display: grid; grid-template-columns: 1fr; gap: 3.2rem; align-items: start; }
  @media screen and (min-width: 990px) { .feed-herogrid { grid-template-columns: 1.6fr 1fr; gap: 4rem; } }

  /* quote card (brand card style) */
  .feed-qcard { background: rgb(var(--color-background)); border: 1px solid rgba(var(--color-foreground), 0.12); border-radius: 1rem; padding: 2.4rem 2.2rem; }
  .feed-qcard__label { display: inline-block; font-size: 1.1rem; letter-spacing: 0.18rem; text-transform: uppercase; color: rgba(var(--color-foreground), 0.6); margin-bottom: 0.6rem; }
  .feed-qcard__title { font-size: 1.9rem; font-weight: 600; margin: 0 0 1.4rem; line-height: 1.2; }
  .feed-qcard__list { list-style: none; margin: 0 0 2rem; padding: 0; display: grid; gap: 0.8rem; }
  .feed-qcard__list li { position: relative; padding-left: 2.6rem; font-size: 1.4rem; line-height: 1.45; color: rgba(var(--color-foreground), 0.82); }
  .feed-qcard__list li svg { position: absolute; left: 0; top: 0.1rem; color: var(--feed-gold); }
  .feed-qcard .button { width: 100%; margin-bottom: 1rem; }
  .feed-qcard__or { text-align: center; font-size: 1.3rem; color: rgba(var(--color-foreground), 0.6); margin: 0; }
  .feed-qcard__or a { color: inherit; font-weight: 600; }

  /* trust stat row (match clients-marquee stats) */
  .feed-statrow { display: flex; flex-wrap: wrap; gap: 2rem 3.4rem; margin-top: 3rem; padding-top: 2.6rem; border-top: 1px solid rgba(var(--color-foreground), 0.1); }
  .feed-statitem strong { display: block; font-size: 2.6rem; font-weight: 700; line-height: 1; color: var(--feed-gold); }
  .feed-statitem span { display: block; font-size: 1.3rem; color: rgba(var(--color-foreground), 0.65); margin-top: 0.5rem; }

  /* clients strip (match clients-marquee) */
  .feed-clients { text-align: center; margin: 4rem 0 0; }
  .feed-clients__label { font-size: 1.2rem; letter-spacing: 0.3rem; text-transform: uppercase; color: rgba(var(--color-foreground), 0.55); margin-bottom: 1.6rem; }
  .feed-clients__wrap { position: relative; width: 100vw; margin-left: calc(50% - 50vw); overflow: hidden; padding: 0.4rem 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
  .feed-clients__track { display: flex; width: max-content; gap: 4.8rem; align-items: center; animation: feedclients 55s linear infinite; }
  .feed-clients__track:hover { animation-play-state: paused; }
  .feed-clients__brand { font-size: 1.6rem; font-weight: 600; color: rgba(var(--color-foreground), 0.4); white-space: nowrap; }
  @keyframes feedclients { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .feed-clients__track { animation: none; flex-wrap: wrap; justify-content: center; } }

  /* AEO quick answer */
  .feed-answer { background: rgba(var(--color-foreground), 0.04); border-left: 3px solid var(--feed-gold); padding: 2rem 2.4rem; margin: 3.4rem 0; font-size: 1.6rem; line-height: 1.65; max-width: 82rem; }
  .feed-answer__label { font-size: 1.1rem; letter-spacing: 0.18rem; text-transform: uppercase; color: rgba(var(--color-foreground), 0.6); font-weight: 600; margin-bottom: 0.7rem; }
  .feed-answer p:last-child { margin-bottom: 0; }

  /* prose */
  .feed-body { font-size: 1.6rem; line-height: 1.75; max-width: 82rem; }
  .feed-body h2 { font-size: clamp(2.2rem, 3.6vw, 3.2rem); line-height: 1.15; margin: 3.4rem 0 1.2rem; }
  .feed-body h3 { font-size: 1.9rem; margin: 2.6rem 0 1rem; }
  .feed-body ul, .feed-body ol { padding-left: 2rem; }
  .feed-body li { margin-bottom: 0.6rem; }

  .feed-blocktitle { font-size: clamp(2.2rem, 3.6vw, 3.2rem); line-height: 1.15; margin: 4rem 0 0.6rem; }
  .feed-blockintro { font-size: 1.5rem; color: rgba(var(--color-foreground), 0.7); margin: 0 0 2rem; max-width: 70rem; }

  /* card grids share brand card look */
  .feed-card { background: rgb(var(--color-background)); border: 1px solid rgba(var(--color-foreground), 0.1); border-radius: 1rem; transition: transform 0.4s cubic-bezier(0.2,0.8,0.2,1), border-color 0.3s ease, box-shadow 0.3s ease; }
  .feed-card:hover { transform: translateY(-4px); border-color: rgba(245,180,0,0.5); box-shadow: 0 0.6rem 2rem rgba(212,160,23,0.12); }

  .feed-features { display: grid; grid-template-columns: 1fr; gap: 1.6rem; margin: 2.2rem 0; }
  @media screen and (min-width: 750px) { .feed-features { grid-template-columns: repeat(2, 1fr); } }
  @media screen and (min-width: 990px) { .feed-features { grid-template-columns: repeat(2, 1fr); } }
  .feed-feature { padding: 2.2rem 2rem; }
  .feed-feature__icon { width: 3.2rem; height: 3.2rem; color: var(--feed-gold); margin-bottom: 1.2rem; display: flex; align-items: center; justify-content: center; }
  .feed-feature__title { font-size: 1.7rem; font-weight: 600; margin: 0 0 0.5rem; }
  .feed-feature__text { font-size: 1.45rem; line-height: 1.55; color: rgba(var(--color-foreground), 0.72); margin: 0; }

  /* stats cards */
  .feed-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.6rem; margin: 3rem 0; }
  @media screen and (min-width: 750px) { .feed-stats { grid-template-columns: repeat(4, 1fr); } }
  .feed-stat { padding: 2rem 1.4rem; text-align: center; }
  .feed-stat__num { font-size: 3rem; font-weight: 700; line-height: 1; color: var(--feed-gold); }
  .feed-stat__label { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.7); margin-top: 0.7rem; }

  /* steps (match howto number badge) */
  .feed-steps { display: grid; grid-template-columns: 1fr; gap: 2.4rem 1.6rem; margin: 3.2rem 0 2.4rem; }
  @media screen and (min-width: 750px) { .feed-steps { grid-template-columns: repeat(2, 1fr); } }
  .feed-step { position: relative; padding: 2.4rem 2rem 2rem; text-align: center; }
  .feed-step__num { position: absolute; top: -1.4rem; left: 50%; transform: translateX(-50%); width: 2.8rem; height: 2.8rem; border-radius: 50%; background: linear-gradient(135deg, var(--feed-gold), var(--feed-gold-2)); color: #1a1a2e; font-weight: 700; font-size: 1.3rem; display: flex; align-items: center; justify-content: center; box-shadow: 0 0.4rem 1rem rgba(212,160,23,0.4); }
  .feed-step__title { font-size: 1.6rem; font-weight: 600; margin: 0.6rem 0 0.4rem; }
  .feed-step__text { font-size: 1.4rem; line-height: 1.5; color: rgba(var(--color-foreground), 0.7); margin: 0; }

  /* price table */
  .feed-table-wrap { overflow-x: auto; margin: 2.2rem 0; border: 1px solid rgba(var(--color-foreground), 0.12); border-radius: 1rem; }
  .feed-table { width: 100%; border-collapse: collapse; font-size: 1.5rem; }
  .feed-table th, .feed-table td { text-align: left; padding: 1.4rem 1.8rem; border-bottom: 1px solid rgba(var(--color-foreground), 0.1); }
  .feed-table thead th { font-size: 1.2rem; letter-spacing: 0.06rem; text-transform: uppercase; color: rgba(var(--color-foreground), 0.6); background: rgba(var(--color-foreground), 0.03); }
  .feed-table tbody tr:last-child td { border-bottom: none; }
  .feed-table td:last-child { font-weight: 700; white-space: nowrap; color: var(--feed-gold); }
  .feed-price-caption { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.6); margin-top: 1rem; }

  /* why band */
  .feed-why { margin: 4.4rem 0 0; padding: 3.4rem 2.8rem; border: 1px solid rgba(var(--color-foreground), 0.1); border-radius: 1.2rem; background: rgba(var(--color-foreground), 0.02); }
  .feed-why__grid { display: grid; grid-template-columns: 1fr; gap: 2rem; margin-top: 2rem; }
  @media screen and (min-width: 750px) { .feed-why__grid { grid-template-columns: repeat(2, 1fr); } }
  @media screen and (min-width: 990px) { .feed-why__grid { grid-template-columns: repeat(4, 1fr); } }
  .feed-why__item { display: flex; gap: 1.2rem; align-items: flex-start; }
  .feed-why__icon { flex: 0 0 auto; color: var(--feed-gold); }
  .feed-why__t { font-size: 1.55rem; font-weight: 600; margin: 0 0 0.3rem; }
  .feed-why__d { font-size: 1.35rem; line-height: 1.5; color: rgba(var(--color-foreground), 0.72); margin: 0; }

  /* FAQ */
  .feed-faq { margin: 2.2rem 0; max-width: 82rem; }
  .feed-faq details { border-bottom: 1px solid rgba(var(--color-foreground), 0.14); padding: 1.6rem 0; }
  .feed-faq summary { font-size: 1.65rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: 1.2rem; }
  .feed-faq summary::-webkit-details-marker { display: none; }
  .feed-faq summary::after { content: '+'; color: var(--feed-gold); font-size: 2.2rem; line-height: 1; }
  .feed-faq details[open] summary::after { content: '\2013'; }
  .feed-faq__a { font-size: 1.5rem; line-height: 1.65; color: rgba(var(--color-foreground), 0.8); margin-top: 1.1rem; }

  /* CTA band (match howto cta) */
  .feed-ctaband { margin: 4.4rem 0 0; padding: 3.2rem 2.4rem; text-align: center; border-radius: 1.2rem; background: linear-gradient(135deg, rgba(245,180,0,0.1), rgba(116,73,200,0.06)); border: 1px solid rgba(245,180,0,0.22); }
  .feed-ctaband h2 { margin: 0 0 0.8rem; font-size: clamp(2rem, 3.2vw, 2.6rem); }
  .feed-ctaband p { font-size: 1.5rem; color: rgba(var(--color-foreground), 0.78); margin: 0 auto 1.8rem; max-width: 58rem; }
  .feed-ctaband__row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }

  /* related products */
  .feed-related { margin: 4.4rem 0 0; }
  .feed-related h2 { font-size: clamp(2.2rem, 3.6vw, 3.2rem); margin: 0 0 1.6rem; }
  .feed-related .product-grid { margin: 0; }

  /* contact band */
  .feed-contact { margin: 4.4rem 0 0; padding: 3.4rem 2.8rem; border: 1px solid rgba(var(--color-foreground), 0.1); border-radius: 1.2rem; }
  .feed-contact__grid { display: grid; grid-template-columns: 1fr; gap: 2.4rem; align-items: center; }
  @media screen and (min-width: 750px) { .feed-contact__grid { grid-template-columns: 1.2fr 1fr; } }
  .feed-contact h2 { font-size: clamp(2rem, 3.2vw, 2.4rem); margin: 0 0 0.8rem; }
  .feed-contact p { font-size: 1.5rem; color: rgba(var(--color-foreground), 0.75); margin: 0 0 1.6rem; }
  .feed-contact__lines { display: grid; gap: 1rem; }
  .feed-contact__line { display: flex; align-items: center; gap: 1rem; font-size: 1.55rem; }
  .feed-contact__line a { color: inherit; text-decoration: none; font-weight: 600; }
  .feed-contact__line a:hover { color: var(--feed-gold); }
  .feed-contact__ic { flex: 0 0 auto; color: var(--feed-gold); }
  .feed-contact__cta { display: grid; gap: 1rem; }
  .feed-contact__cta .button { width: 100%; }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient feed-ld-{{ section.id }}">
  <div class="page-width feed-pad">

    {%- if section.settings.show_breadcrumb -%}
      <nav class="feed-breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a> &rsaquo;
        <a href="/pages/feeds">Feeds</a> &rsaquo;
        <span>{{ section.settings.breadcrumb_label | default: page.title }}</span>
      </nav>
    {%- endif -%}

    {%- comment -%} ---------- HERO ---------- {%- endcomment -%}
    <div class="feed-herogrid">
      <header class="feed-hero">
        {%- if section.settings.eyebrow != blank -%}<span class="feed-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}<h1>{{ page.title }}</h1>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="feed-sub">{{ section.settings.subheading }}</p>{%- endif -%}
        <div class="feed-actions">
          <a class="button button--primary" href="{{ primary_url }}" target="_blank" rel="noopener">{{ section.settings.primary_cta_label | default: 'Get a quote on WhatsApp' }}</a>
          <a class="button button--secondary" href="tel:{{ phone_tel }}">Call {{ phone_display }}</a>
          {%- if section.settings.secondary_cta_label != blank -%}
            <a class="button button--secondary" href="{{ section.settings.secondary_cta_url | default: '/collections/all' }}">{{ section.settings.secondary_cta_label }}</a>
          {%- endif -%}
        </div>

        {%- if section.settings.show_trust_stats and section.settings.trust_stats != blank -%}
          <div class="feed-statrow">
            {%- assign stat_pairs = section.settings.trust_stats | split: '·' -%}
            {%- for pair in stat_pairs limit: 4 -%}
              {%- assign kv = pair | split: '|' -%}
              <div class="feed-statitem"><strong>{{ kv[0] | strip }}</strong><span>{{ kv[1] | strip }}</span></div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </header>

      {%- if section.settings.show_quote_card -%}
        <aside class="feed-qcard">
          <span class="feed-qcard__label">Free quote</span>
          <p class="feed-qcard__title">{{ section.settings.quote_card_title | default: 'Tell us what you need' }}</p>
          <ul class="feed-qcard__list">
            <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Free design mock-up before you pay</li>
            <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>No minimum order quantity</li>
            <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>GST invoice for companies &amp; schools</li>
            <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Dispatch in 5–7 days, pan-India</li>
          </ul>
          <a class="button button--primary" href="{{ primary_url }}" target="_blank" rel="noopener">Get a quote on WhatsApp</a>
          <a class="button button--secondary" href="tel:{{ phone_tel }}">Call {{ phone_display }}</a>
          <p class="feed-qcard__or">or email <a href="mailto:{{ email }}">{{ email }}</a></p>
        </aside>
      {%- endif -%}
    </div>

    {%- comment -%} ---------- CLIENTS STRIP ---------- {%- endcomment -%}
    {%- if section.settings.show_clients and section.settings.clients_brands != blank -%}
      <div class="feed-clients">
        <div class="feed-clients__label">{{ section.settings.clients_label | default: 'Trusted by 150+ brands, schools & sports bodies across India' }}</div>
        <div class="feed-clients__wrap">
          <div class="feed-clients__track">
            {%- assign brands = section.settings.clients_brands | split: '·' -%}
            {%- for b in brands -%}<span class="feed-clients__brand">{{ b | strip }}</span>{%- endfor -%}
            {%- for b in brands -%}<span class="feed-clients__brand" aria-hidden="true">{{ b | strip }}</span>{%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ---------- IN-FLOW BLOCKS ---------- {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'quick_answer' -%}
          <div class="feed-answer" {{ block.shopify_attributes }}>
            <div class="feed-answer__label">{{ block.settings.label | default: 'Quick answer' }}</div>
            {{ block.settings.text }}
          </div>
        {%- when 'rich_text' -%}
          <div class="feed-body" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}<h2 class="feed-blocktitle">{{ block.settings.heading }}</h2>{%- endif -%}
            {{ block.settings.text }}
          </div>
        {%- when 'cta_band' -%}
          <div class="feed-ctaband" {{ block.shopify_attributes }}>
            <h2>{{ block.settings.heading | default: 'Ready to order?' }}</h2>
            {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
            <div class="feed-ctaband__row">
              <a class="button button--primary" href="{{ primary_url }}" target="_blank" rel="noopener">{{ block.settings.button_label | default: 'Message us on WhatsApp' }}</a>
              <a class="button button--secondary" href="tel:{{ phone_tel }}">Call {{ phone_display }}</a>
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}

    {%- comment -%} ---------- STAT CARDS ---------- {%- endcomment -%}
    {%- if stat_blocks.size > 0 -%}
      <div class="feed-stats">
        {%- for block in stat_blocks -%}
          <div class="feed-card feed-stat" {{ block.shopify_attributes }}>
            <div class="feed-stat__num">{{ block.settings.number }}</div>
            <div class="feed-stat__label">{{ block.settings.label }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ---------- FEATURE CARDS ---------- {%- endcomment -%}
    {%- if feature_blocks.size > 0 -%}
      {%- if section.settings.features_heading != blank -%}<h2 class="feed-blocktitle">{{ section.settings.features_heading }}</h2>{%- endif -%}
      <div class="feed-features">
        {%- for block in feature_blocks -%}
          <div class="feed-card feed-feature" {{ block.shopify_attributes }}>
            <div class="feed-feature__icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p class="feed-feature__title">{{ block.settings.title }}</p>
            <p class="feed-feature__text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ---------- STEPS ---------- {%- endcomment -%}
    {%- if step_blocks.size > 0 -%}
      {%- if section.settings.steps_heading != blank -%}<h2 class="feed-blocktitle">{{ section.settings.steps_heading }}</h2>{%- endif -%}
      <div class="feed-steps">
        {%- for block in step_blocks -%}
          <div class="feed-card feed-step" {{ block.shopify_attributes }}>
            <div class="feed-step__num">{{ forloop.index }}</div>
            <p class="feed-step__title">{{ block.settings.title }}</p>
            <p class="feed-step__text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ---------- PRICE TABLE ---------- {%- endcomment -%}
    {%- if price_blocks.size > 0 -%}
      {%- if section.settings.price_heading != blank -%}<h2 class="feed-blocktitle">{{ section.settings.price_heading }}</h2>{%- endif -%}
      <div class="feed-table-wrap">
        <table class="feed-table">
          <thead><tr>
            <th>{{ section.settings.price_col1 | default: 'Item' }}</th>
            <th>{{ section.settings.price_col2 | default: 'Details' }}</th>
            <th>{{ section.settings.price_col3 | default: 'Price (from)' }}</th>
          </tr></thead>
          <tbody>
            {%- for block in price_blocks -%}
              <tr {{ block.shopify_attributes }}>
                <td>{{ block.settings.item }}</td>
                <td>{{ block.settings.spec }}</td>
                <td>{{ block.settings.price }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
      {%- if section.settings.price_caption != blank -%}<p class="feed-price-caption">{{ section.settings.price_caption }}</p>{%- endif -%}
    {%- endif -%}

    {%- comment -%} ---------- WHY MERU TROPHY ---------- {%- endcomment -%}
    {%- if section.settings.show_why -%}
      <div class="feed-why">
        <h2 class="feed-blocktitle" style="margin-top:0;">{{ section.settings.why_heading | default: 'Why order from Meru Trophy' }}</h2>
        <div class="feed-why__grid">
          <div class="feed-why__item">
            <span class="feed-why__icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span>
            <div><p class="feed-why__t">20+ years of craft</p><p class="feed-why__d">A trusted Bangalore manufacturer with two decades of award-making experience.</p></div>
          </div>
          <div class="feed-why__item">
            <span class="feed-why__icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
            <div><p class="feed-why__t">Full customisation</p><p class="feed-why__d">Free design, engraving and full-colour logo printing on every order.</p></div>
          </div>
          <div class="feed-why__item">
            <span class="feed-why__icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span>
            <div><p class="feed-why__t">Pan-India delivery</p><p class="feed-why__d">Shipped to 20+ cities and 500+ pin codes, with worldwide options.</p></div>
          </div>
          <div class="feed-why__item">
            <span class="feed-why__icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/></svg></span>
            <div><p class="feed-why__t">GST invoicing</p><p class="feed-why__d">Proper GST bills for companies, schools, clubs and government orders.</p></div>
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ---------- FAQ ---------- {%- endcomment -%}
    {%- if faq_blocks.size > 0 -%}
      <h2 class="feed-blocktitle">{{ section.settings.faq_heading | default: 'Frequently asked questions' }}</h2>
      <div class="feed-faq">
        {%- for block in faq_blocks -%}
          <details {{ block.shopify_attributes }}{% if forloop.first %} open{% endif %}>
            <summary>{{ block.settings.question }}</summary>
            <div class="feed-faq__a">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ---------- RELATED PRODUCTS ---------- {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'related_collection' -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- if coll != blank and coll.products_count > 0 -%}
          <div class="feed-related" {{ block.shopify_attributes }}>
            <h2>{{ block.settings.heading | default: 'Popular in this range' }}</h2>
            <ul class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--4-col-desktop grid--2-col-tablet-down" role="list">
              {%- assign skip_card_styles = false -%}
              {%- for product in coll.products limit: 4 -%}
                <li class="grid__item">
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: 'square',
                    show_secondary_image: false,
                    show_vendor: false,
                    show_rating: false,
                    skip_styles: skip_card_styles,
                    section_id: section.id,
                    lazy_load: true
                  %}
                </li>
                {%- assign skip_card_styles = true -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} ---------- CONTACT BAND ---------- {%- endcomment -%}
    {%- if section.settings.show_contact -%}
      <div class="feed-contact">
        <div class="feed-contact__grid">
          <div>
            <h2>{{ section.settings.contact_heading | default: 'Talk to a trophy specialist' }}</h2>
            <p>{{ section.settings.contact_text | default: 'Share your event, quantity and date — we’ll send designs and a quote, usually within the hour. Open Mon–Sat, 10am–8pm.' }}</p>
            <div class="feed-contact__lines">
              <div class="feed-contact__line">
                <svg class="feed-contact__ic" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:{{ phone_tel }}">{{ phone_display }}</a> &nbsp;·&nbsp; <a href="tel:{{ phone2_tel }}">{{ phone2_display }}</a>
              </div>
              <div class="feed-contact__line">
                <svg class="feed-contact__ic" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:{{ email }}">{{ email }}</a>
              </div>
            </div>
          </div>
          <div class="feed-contact__cta">
            <a class="button button--primary" href="{{ primary_url }}" target="_blank" rel="noopener">Chat on WhatsApp</a>
            <a class="button button--secondary" href="/pages/feeds">Explore more guides</a>
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{%- comment -%} ---------- JSON-LD structured data for SEO + AI citation ---------- {%- endcomment -%}
{%- capture page_url -%}{{ shop.url }}{{ page.url }}{%- endcapture -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}" },
    { "@type": "ListItem", "position": 2, "name": "Feeds", "item": "{{ shop.url }}/pages/feeds" },
    { "@type": "ListItem", "position": 3, "name": {{ section.settings.breadcrumb_label | default: page.title | json }}, "item": "{{ page_url }}" }
  ]
}
</script>

{%- if faq_blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in faq_blocks -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | json }} }
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{%- if section.settings.schema_type == 'Product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ section.settings.schema_name | default: page.title | json }},
  "description": {{ page.metafields.global.description_tag | default: section.settings.subheading | strip_html | json }},
  "brand": { "@type": "Brand", "name": "Meru Trophy" },
  "url": "{{ page_url }}"
  {%- if section.settings.schema_price_low != blank -%},
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "INR",
    "lowPrice": "{{ section.settings.schema_price_low }}"{% if section.settings.schema_price_high != blank %},
    "highPrice": "{{ section.settings.schema_price_high }}"{% endif %},
    "seller": { "@type": "Organization", "name": "Meru Trophy" }
  }
  {%- endif -%}
}
</script>
{%- elsif section.settings.schema_type == 'Service' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": {{ section.settings.schema_name | default: page.title | json }},
  "provider": { "@type": "Organization", "name": "Meru Trophy", "url": "{{ shop.url }}", "telephone": "+917892207252" },
  "areaServed": "IN",
  "url": "{{ page_url }}"
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Feed Landing",
  "tag": "section",
  "class": "feed-landing-section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "richtext", "id": "heading", "label": "Heading (H1)", "info": "Use <h1>…</h1>. Wrap a phrase in <em></em> for the gold gradient." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "primary_cta_label", "label": "Primary CTA label", "default": "Get a quote on WhatsApp" },
    { "type": "url", "id": "primary_cta_url", "label": "Primary CTA URL", "info": "Leave blank to default to WhatsApp." },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label", "default": "Browse the catalogue" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL" },
    { "type": "header", "content": "Hero quote card" },
    { "type": "checkbox", "id": "show_quote_card", "label": "Show quote card", "default": true },
    { "type": "text", "id": "quote_card_title", "label": "Quote card title", "default": "Tell us what you need" },
    { "type": "header", "content": "Trust stats bar" },
    { "type": "checkbox", "id": "show_trust_stats", "label": "Show trust stats", "default": true },
    { "type": "textarea", "id": "trust_stats", "label": "Stats", "info": "Up to 4, separated by ·  — each is number|label.", "default": "20+|Years of craft · 10,000+|Awards delivered · 150+|Brands served · Pan-India|Fast delivery" },
    { "type": "header", "content": "Clients strip" },
    { "type": "checkbox", "id": "show_clients", "label": "Show clients strip", "default": true },
    { "type": "text", "id": "clients_label", "label": "Clients label", "default": "Trusted by 150+ brands, schools & sports bodies across India" },
    { "type": "textarea", "id": "clients_brands", "label": "Brand names", "info": "Separated by ·", "default": "Tanishq · HDFC Bank · Amazon · ITC · Titan · Caratlane · Kalyan Jewellers · Maruti Suzuki · Mercedes Benz · Schneider Electric · Cadbury · Indian Express · HCL · Infosys · Jio · SBI · Decathlon · KSCA · HAL · Indian Railways · RVCE · Foxconn · Mondelez · Razorpay · CRED" },
    { "type": "header", "content": "Why Meru Trophy band" },
    { "type": "checkbox", "id": "show_why", "label": "Show why-Meru band", "default": true },
    { "type": "text", "id": "why_heading", "label": "Heading", "default": "Why order from Meru Trophy" },
    { "type": "header", "content": "Contact band" },
    { "type": "checkbox", "id": "show_contact", "label": "Show contact band", "default": true },
    { "type": "text", "id": "contact_heading", "label": "Heading", "default": "Talk to a trophy specialist" },
    { "type": "textarea", "id": "contact_text", "label": "Text", "default": "Share your event, quantity and date — we’ll send designs and a quote, usually within the hour. Open Mon–Sat, 10am–8pm." },
    { "type": "header", "content": "Breadcrumb" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "text", "id": "breadcrumb_label", "label": "Breadcrumb / current page label" },
    { "type": "header", "content": "Section block headings" },
    { "type": "text", "id": "features_heading", "label": "Features heading" },
    { "type": "text", "id": "steps_heading", "label": "Steps heading" },
    { "type": "header", "content": "Price table" },
    { "type": "text", "id": "price_heading", "label": "Price table heading" },
    { "type": "text", "id": "price_col1", "label": "Column 1 label", "default": "Item" },
    { "type": "text", "id": "price_col2", "label": "Column 2 label", "default": "Details" },
    { "type": "text", "id": "price_col3", "label": "Column 3 label", "default": "Price (from)" },
    { "type": "text", "id": "price_caption", "label": "Price caption" },
    { "type": "text", "id": "faq_heading", "label": "FAQ heading", "default": "Frequently asked questions" },
    { "type": "header", "content": "Structured data (JSON-LD)" },
    { "type": "select", "id": "schema_type", "label": "Schema type", "options": [ {"value":"none","label":"None"}, {"value":"Product","label":"Product"}, {"value":"Service","label":"Service"} ], "default": "Product" },
    { "type": "text", "id": "schema_name", "label": "Schema name" },
    { "type": "text", "id": "schema_price_low", "label": "Schema low price (INR, number only)" },
    { "type": "text", "id": "schema_price_high", "label": "Schema high price (INR, number only)" },
    { "type": "header", "content": "Layout" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 64 }
  ],
  "blocks": [
    { "type": "quick_answer", "name": "Quick answer (AEO box)", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Quick answer" },
      { "type": "richtext", "id": "text", "label": "Answer", "info": "1–3 sentence direct answer for AI engines & featured snippets." }
    ]},
    { "type": "rich_text", "name": "Rich text", "settings": [
      { "type": "text", "id": "heading", "label": "Heading (H2)" },
      { "type": "richtext", "id": "text", "label": "Body" }
    ]},
    { "type": "feature", "name": "Feature", "settings": [
      { "type": "text", "id": "title", "label": "Title" },
      { "type": "textarea", "id": "text", "label": "Text" }
    ]},
    { "type": "stat", "name": "Stat", "settings": [
      { "type": "text", "id": "number", "label": "Number", "default": "20+" },
      { "type": "text", "id": "label", "label": "Label", "default": "Years" }
    ]},
    { "type": "price_row", "name": "Price row", "settings": [
      { "type": "text", "id": "item", "label": "Item" },
      { "type": "text", "id": "spec", "label": "Details" },
      { "type": "text", "id": "price", "label": "Price" }
    ]},
    { "type": "step", "name": "Step", "settings": [
      { "type": "text", "id": "title", "label": "Title" },
      { "type": "textarea", "id": "text", "label": "Text" }
    ]},
    { "type": "faq", "name": "FAQ", "settings": [
      { "type": "text", "id": "question", "label": "Question" },
      { "type": "richtext", "id": "answer", "label": "Answer" }
    ]},
    { "type": "cta_band", "name": "CTA band", "settings": [
      { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to order?" },
      { "type": "textarea", "id": "text", "label": "Text" },
      { "type": "text", "id": "button_label", "label": "Button label", "default": "Message us on WhatsApp" }
    ]},
    { "type": "related_collection", "name": "Related collection", "settings": [
      { "type": "text", "id": "heading", "label": "Heading", "default": "Popular in this range" },
      { "type": "collection", "id": "collection", "label": "Collection" }
    ]}
  ],
  "presets": [ { "name": "Feed Landing", "category": "Meru Trophy" } ]
}
{% endschema %}
