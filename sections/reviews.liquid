{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .reviews-hero { text-align: center; padding-bottom: 2.4rem; }
  .reviews-hero__title { margin: 0 0 1.2rem; }
  .reviews-hero__rating {
    display: inline-flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
    justify-content: center; font-size: 1.6rem;
  }
  .reviews-hero__score { font-size: 3.2rem; font-weight: 600; line-height: 1; }
  .reviews-hero__stars { color: #f5b400; letter-spacing: 0.2rem; font-size: 2rem; }
  .reviews-hero__count { color: rgba(var(--color-foreground), 0.75); }
  .reviews-hero__cta { margin-top: 1.8rem; }
  .reviews-hero__cta .button { min-width: 24rem; }

  .reviews-controls {
    display: flex; justify-content: space-between; align-items: center; gap: 1.2rem;
    flex-wrap: wrap; margin-bottom: 1.6rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
    padding: 1.2rem 0;
  }
  .reviews-controls__label { font-size: 1.4rem; color: rgba(var(--color-foreground), 0.75); }
  .reviews-controls__sort select {
    border: 1px solid rgba(var(--color-foreground), 0.2);
    background: transparent; color: rgb(var(--color-foreground));
    padding: 0.6rem 2.4rem 0.6rem 1rem; font-size: 1.4rem; border-radius: 0.4rem;
  }

  .reviews-grid {
    display: grid; gap: 1.6rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 750px) { .reviews-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 990px) { .reviews-grid { grid-template-columns: repeat(3, 1fr); } }

  .review-card {
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 0.8rem;
    padding: 2rem;
    display: flex; flex-direction: column; gap: 1rem;
    transition: box-shadow 0.2s ease;
  }
  .review-card:hover { box-shadow: 0 0.4rem 1.6rem rgba(var(--color-foreground), 0.08); }
  .review-card__head { display: flex; gap: 1.2rem; align-items: center; }
  .review-card__avatar {
    width: 4.4rem; height: 4.4rem; border-radius: 50%;
    background: rgba(var(--color-foreground), 0.08);
    display: flex; align-items: center; justify-content: center;
    font-weight: 600; font-size: 1.6rem; flex-shrink: 0;
    color: rgb(var(--color-foreground));
  }
  .review-card__meta { display: flex; flex-direction: column; min-width: 0; }
  .review-card__name { font-weight: 600; font-size: 1.5rem; line-height: 1.3; }
  .review-card__date { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.6); margin-top: 0.2rem; }
  .review-card__stars { color: #f5b400; letter-spacing: 0.1rem; font-size: 1.5rem; }
  .review-card__stars .star-empty { color: rgba(var(--color-foreground), 0.2); }
  .review-card__text { font-size: 1.4rem; line-height: 1.6; color: rgb(var(--color-foreground)); }
  .review-card__text--empty { color: rgba(var(--color-foreground), 0.5); font-style: italic; }

  .reviews-loadmore { text-align: center; margin-top: 2.4rem; }
  .reviews-empty { text-align: center; padding: 4rem 0; color: rgba(var(--color-foreground), 0.6); }

  .reviews-google-badge {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 1.3rem; color: rgba(var(--color-foreground), 0.65);
    margin-top: 0.6rem;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="reviews-hero">
      <h1 class="reviews-hero__title h0">{{ section.settings.heading | default: 'What our customers say' }}</h1>
      <div class="reviews-hero__rating">
        <span class="reviews-hero__score" id="reviews-avg">4.9</span>
        <span class="reviews-hero__stars" aria-label="4.9 out of 5 stars">★★★★★</span>
        <span class="reviews-hero__count">(<span id="reviews-count">442</span> Google reviews)</span>
      </div>
      <div class="reviews-google-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.25 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.83z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38z"/></svg>
        Verified Google reviews
      </div>
      <div class="reviews-hero__cta">
        <a href="{{ section.settings.write_review_url }}" target="_blank" rel="noopener" class="button button--primary">
          {{ section.settings.cta_label | default: 'Write a Review on Google' }}
        </a>
      </div>
    </div>

    <div class="reviews-controls">
      <div class="reviews-controls__label" id="reviews-showing">Showing 0 reviews</div>
      <div class="reviews-controls__sort">
        <label for="reviews-sort" class="visually-hidden">Sort reviews</label>
        <select id="reviews-sort">
          <option value="newest">Newest first</option>
          <option value="highest">Highest rated</option>
          <option value="lowest">Lowest rated</option>
        </select>
      </div>
    </div>

    <div class="reviews-grid" id="reviews-grid" aria-live="polite"></div>
    <div class="reviews-empty" id="reviews-empty" hidden>No reviews to display.</div>
    <div class="reviews-loadmore">
      <button type="button" class="button button--secondary" id="reviews-loadmore-btn">Load more reviews</button>
    </div>
  </div>
</div>

<script>
  (function () {
    var DATA_URL = '{{ 'reviews-data.json' | asset_url }}';
    var PAGE_SIZE = {{ section.settings.page_size | default: 24 }};
    var grid = document.getElementById('reviews-grid');
    var btn = document.getElementById('reviews-loadmore-btn');
    var showing = document.getElementById('reviews-showing');
    var sortSel = document.getElementById('reviews-sort');
    var empty = document.getElementById('reviews-empty');

    var ALL = [];
    var view = [];
    var rendered = 0;

    var unitOrder = { 'minute': 1, 'minutes': 1, 'hour': 60, 'hours': 60, 'day': 1440, 'days': 1440, 'week': 10080, 'weeks': 10080, 'month': 43800, 'months': 43800, 'year': 525600, 'years': 525600 };
    function ageMinutes(d) {
      if (!d) return 9e9;
      var s = d.toLowerCase().replace('edited', '').trim();
      if (s === 'a day ago' || s === '1 day ago') return 1440;
      if (s === 'an hour ago' || s === '1 hour ago') return 60;
      if (s === 'a minute ago') return 1;
      if (s === 'a week ago') return 10080;
      if (s === 'a month ago') return 43800;
      if (s === 'a year ago') return 525600;
      var m = s.match(/(\d+)\s+(minute|minutes|hour|hours|day|days|week|weeks|month|months|year|years)/);
      if (m) return parseInt(m[1], 10) * unitOrder[m[2]];
      return 9e9;
    }

    function initials(name) {
      if (!name) return '?';
      var parts = name.trim().split(/\s+/);
      var s = parts[0][0];
      if (parts.length > 1) s += parts[parts.length - 1][0];
      return s.toUpperCase();
    }

    function stars(n) {
      n = Math.max(0, Math.min(5, n || 0));
      var html = '';
      for (var i = 0; i < 5; i++) {
        html += i < n ? '★' : '<span class="star-empty">★</span>';
      }
      return html;
    }

    function escapeHtml(s) {
      return String(s || '').replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function card(r) {
      var hasText = r.text && r.text.length > 0;
      return '<article class="review-card">' +
        '<div class="review-card__head">' +
          '<div class="review-card__avatar" aria-hidden="true">' + escapeHtml(initials(r.name)) + '</div>' +
          '<div class="review-card__meta">' +
            '<span class="review-card__name">' + escapeHtml(r.name) + '</span>' +
            '<span class="review-card__date">' + escapeHtml(r.date) + '</span>' +
          '</div>' +
        '</div>' +
        '<div class="review-card__stars" aria-label="' + r.rating + ' out of 5 stars">' + stars(r.rating) + '</div>' +
        '<p class="review-card__text' + (hasText ? '' : ' review-card__text--empty') + '">' +
          (hasText ? escapeHtml(r.text) : 'Rated ' + r.rating + ' stars') +
        '</p>' +
      '</article>';
    }

    function renderNext() {
      var end = Math.min(rendered + PAGE_SIZE, view.length);
      var html = '';
      for (var i = rendered; i < end; i++) html += card(view[i]);
      grid.insertAdjacentHTML('beforeend', html);
      rendered = end;
      showing.textContent = 'Showing ' + rendered + ' of ' + view.length + ' reviews';
      btn.style.display = rendered >= view.length ? 'none' : '';
      empty.hidden = view.length > 0;
    }

    function reset(sortMode) {
      grid.innerHTML = '';
      rendered = 0;
      view = ALL.slice();
      if (sortMode === 'highest') view.sort(function (a, b) { return b.rating - a.rating || ageMinutes(a.date) - ageMinutes(b.date); });
      else if (sortMode === 'lowest') view.sort(function (a, b) { return a.rating - b.rating || ageMinutes(a.date) - ageMinutes(b.date); });
      else view.sort(function (a, b) { return ageMinutes(a.date) - ageMinutes(b.date); });
      renderNext();
    }

    btn.addEventListener('click', renderNext);
    sortSel.addEventListener('change', function () { reset(sortSel.value); });

    fetch(DATA_URL).then(function (r) { return r.json(); }).then(function (data) {
      ALL = data || [];
      document.getElementById('reviews-count').textContent = ALL.length;
      reset('newest');
    }).catch(function () {
      empty.hidden = false;
      btn.style.display = 'none';
      showing.textContent = '';
    });
  })();
</script>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "text",
      "id": "write_review_url",
      "label": "Write a review URL (Google Business)",
      "default": "https://share.google/Fhoc3O7ymZtYxuCZF"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Write a Review on Google"
    },
    {
      "type": "range",
      "id": "page_size",
      "min": 6,
      "max": 60,
      "step": 6,
      "label": "Reviews per page",
      "default": 24
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "category": "Custom"
    }
  ]
}
{% endschema %}
