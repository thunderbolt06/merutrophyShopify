{%- comment -%}
  Map Embed — responsive Google Maps iframe for the Meru Trophy location.
  Theme-consistent: color-scheme wrapper, .section-{id}-padding, .page-width,
  native .button for directions, gold used only as an <em> heading accent.
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .map-embed__head { text-align: center; margin-bottom: 2.4rem; }
  .map-embed__eyebrow { display: inline-block; font-size: 1.2rem; letter-spacing: 0.3rem; text-transform: uppercase; color: rgba(var(--color-foreground), 0.6); margin-bottom: 0.8rem; }
  .map-embed__title { margin: 0 0 0.8rem; font-size: clamp(2.2rem, 3.6vw, 3.2rem); line-height: 1.15; }
  .map-embed__title em { font-style: normal; background: linear-gradient(135deg, #d4a017, #f5b400); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .map-embed__sub { margin: 0 auto; max-width: 56rem; font-size: 1.5rem; color: rgba(var(--color-foreground), 0.72); }
  .map-embed__frame { position: relative; width: 100%; border: 1px solid rgba(var(--color-foreground), 0.12); border-radius: 1rem; overflow: hidden; background: rgba(var(--color-foreground), 0.04); }
  .map-embed__frame::before { content: ''; display: block; padding-bottom: {{ section.settings.aspect_ratio | default: 45 }}%; }
  .map-embed__frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .map-embed__actions { text-align: center; margin-top: 2rem; }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="map-embed__head">
        {%- if section.settings.eyebrow != blank -%}<span class="map-embed__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="map-embed__title">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="map-embed__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.settings.map_embed_url != blank -%}
      <div class="map-embed__frame">
        <iframe
          src="{{ section.settings.map_embed_url }}"
          title="{{ section.settings.map_title | default: 'Meru Trophy location on Google Maps' | escape }}"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    {%- endif -%}

    {%- if section.settings.directions_url != blank -%}
      <div class="map-embed__actions">
        <a class="button button--primary" href="{{ section.settings.directions_url }}" target="_blank" rel="noopener">
          {{ section.settings.directions_label | default: 'Get directions on Google Maps' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Map Embed",
  "tag": "section",
  "class": "section map-embed-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Visit Us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find us in <em>Bangalore</em>", "info": "Wrap a phrase in <em></em> for the gold accent." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "#273/2, SC Road, 2nd Cross, 1st Floor, Near Annamma Temple, Gandhinagar, Bangalore - 560 009. Same-day pickup available." },
    { "type": "textarea", "id": "map_embed_url", "label": "Google Maps embed URL", "info": "From Google Maps → Share → Embed a map → copy the src URL. A query embed is used by default.", "default": "https://maps.google.com/maps?q=Meru%20Trophy%2C%20SC%20Road%2C%20Gandhinagar%2C%20Bangalore%20560009&t=&z=15&ie=UTF8&iwloc=&output=embed" },
    { "type": "text", "id": "map_title", "label": "Map title (accessibility)", "default": "Meru Trophy location on Google Maps" },
    { "type": "range", "id": "aspect_ratio", "min": 30, "max": 75, "step": 5, "unit": "%", "label": "Map height (aspect ratio)", "default": 45 },
    { "type": "url", "id": "directions_url", "label": "Directions button URL", "default": "https://maps.app.goo.gl/i8tmRdXttcSA27UE6" },
    { "type": "text", "id": "directions_label", "label": "Directions button label", "default": "Get directions on Google Maps" },
    { "type": "header", "content": "Layout" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 52 }
  ],
  "presets": [ { "name": "Map Embed", "category": "Meru Trophy" } ]
}
{% endschema %}
