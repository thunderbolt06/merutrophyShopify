      assign auto_country = 'United States'
      assign auto_country_code = 'US'
      assign auto_currency = 'USD'
      assign auto_flag = '🇺🇸'
      assign auto_shipping_days = '7-12 business days via DHL/FedEx Express from India'
      assign auto_areas = 'New York, San Francisco Bay Area, Chicago, Houston, Los Angeles, Seattle, Austin, Dallas, New Jersey, Atlanta, Boston, Washington DC'
      assign auto_popular_occasions = 'Diwali gala award nights, cultural association annual felicitations, cricket club tournaments, BAPS and ISKCON temple events, IT company Indo-American leadership awards'
      assign auto_key_buyers = 'IANA (Indian American communities), BAPS temples, Gujarati Samaj USA, Telugu Association of North America (TANA), Kerala Associations, sports and cricket clubs'
      assign auto_diaspora_note = 'The Indian diaspora in the US — over 4 million strong — orders custom trophies and mementos for cultural associations, community events, and diaspora-owned businesses across New York, New Jersey, the Bay Area, and Chicago.'
      assign auto_local_note = 'US shipments are sent via DHL Express or FedEx International Priority. Most US orders arrive in 7-10 business days. Customs duties may apply on import — please check US Customs for applicable rates on trophy/gift imports from India.'
    when 'trophies-to-dubai', 'custom-trophies-dubai', 'trophy-shop-dubai', 'trophies-to-uae'
      assign auto_country = 'Dubai & UAE'
      assign auto_country_code = 'AE'
      assign auto_currency = 'AED'
      assign auto_flag = '🇦🇪'
      assign auto_shipping_days = '4-7 business days via DHL/FedEx from India'
      assign auto_areas = 'Dubai, Abu Dhabi, Sharjah, Ajman, Ras Al Khaimah, DIFC, Business Bay, JLT, Dubai Marina, Deira, Al Quoz, Bur Dubai'
      assign auto_popular_occasions = 'Indian community Diwali and Holi events, cricket tournaments in Dubai, EXPO legacy corporate awards, gold and jewellery sector felicitations, Pravasi Bharatiya community events, company annual days for Indian-led businesses'
      assign auto_key_buyers = 'Indian Business and Professional Council (IBPC Dubai), Gujarat Samachar Dubai, Keralites associations, Indian cricket clubs, Gold Souk and jewellery trade bodies'
      assign auto_diaspora_note = 'Dubai and UAE host over 3.5 million Indians — the largest diaspora community in the Emirates. Meru Trophy ships custom crystal, metal, and acrylic trophies to Dubai for cultural events, cricket tournaments, Diwali galas, and corporate award nights organised by the Indian business community.'
      assign auto_local_note = 'Dubai/UAE shipments arrive in 4-7 business days. UAE typically charges 5% VAT on imports — recipients may pay a small customs handling fee on arrival. We ship via DHL or FedEx with full tracking and commercial invoice.'
    when 'trophies-to-australia', 'custom-trophies-australia'
      assign auto_country = 'Australia'
      assign auto_country_code = 'AU'
      assign auto_currency = 'AUD'
      assign auto_flag = '🇦🇺'
      assign auto_shipping_days = '8-12 business days via DHL/FedEx from India'
      assign auto_areas = 'Sydney, Melbourne, Brisbane, Perth, Adelaide, Canberra, Gold Coast, Parramatta, Liverpool, Dandenong, Sunshine, Blacktown'
      assign auto_popular_occasions = 'Diwali and Navratri cultural events, Indian community association annual days, cricket club tournaments (SACA, VCCA leagues), BAPS temple events, multicultural school award ceremonies'
      assign auto_key_buyers = 'Federation of Indian Associations Australia, BAPS temples across Australia, Indian cricket associations (NSWCA, VCCA), Hindi school Australia, state-level Indian community councils'
      assign auto_diaspora_note = "Australia is home to over 780,000 people of Indian origin, making it one of the world's largest Indian diaspora communities. Meru Trophy has shipped crystal, metal, and wooden mementos to Indian community associations, cricket clubs, and cultural societies in Sydney, Melbourne, Brisbane, and beyond."
      assign auto_local_note = 'Australia shipments arrive in 8-12 business days. Australian Customs may apply import duties on commercial shipments. For cultural or non-profit community events, gifting exemptions may apply — please check with your local customs authority.'
    when 'trophies-to-uk', 'custom-trophies-uk', 'trophy-shop-uk'
      assign auto_country = 'United Kingdom'
      assign auto_country_code = 'GB'
      assign auto_currency = 'GBP'
      assign auto_flag = '🇬🇧'
      assign auto_shipping_days = '7-10 business days via DHL/FedEx from India'
      assign auto_areas = 'London, Birmingham, Leicester, Manchester, Coventry, Wolverhampton, Leeds, Bradford, Southall, Wembley, Harrow, East Ham'
      assign auto_popular_occasions = 'Diwali in Trafalgar Square and Leicester Square, community association annual gala award nights, cricket club trophies for British-Asian leagues, Navratri garba events, school cultural day awards, Hindu temple events (BAPS, Hindu Council UK)'
      assign auto_key_buyers = 'Hindu Council UK, Federation of Hindu Organisations, Gujarati community associations in Leicester and Wembley, British Tamil associations, BAPS Swaminarayan Sanstha UK'
      assign auto_diaspora_note = "The UK has one of the world's most established Indian diaspora communities — over 1.6 million people of Indian origin, particularly in Leicester, Birmingham, London, and Manchester. Meru Trophy ships crystal, metal, and acrylic trophies and mementos for Diwali events, cricket club awards, and community association felicitations across Great Britain."
      assign auto_local_note = 'UK shipments arrive in 7-10 business days. Post-Brexit, imports from India to the UK may attract UK import duties and VAT. We provide a commercial invoice and Harmonised System (HS) code documentation for smooth customs clearance.'
    when 'trophies-to-thailand', 'custom-trophies-thailand'
      assign auto_country = 'Thailand'
      assign auto_country_code = 'TH'
      assign auto_currency = 'THB'
      assign auto_flag = '🇹🇭'
      assign auto_shipping_days = '5-8 business days via DHL/FedEx from India'
      assign auto_areas = 'Bangkok, Phuket, Pattaya, Chiang Mai, Hua Hin, Nonthaburi, Pathum Thani'
      assign auto_popular_occasions = 'Indian community events in Bangkok, MICE conference and hospitality sector awards, Indian temple trust events (Bangkok Hindu Samaj), cricket and sports club trophies'
      assign auto_key_buyers = 'Indian Association of Thailand (IAT), Bangkok Hindu Samaj, Indian Businessmen Association Thailand, hospitality and MICE sector companies ordering conference awards'
      assign auto_diaspora_note = "Thailand has a small but active Indian diaspora community, particularly in Bangkok's Pahurat district (Little India). Meru Trophy ships custom trophies for Indian community associations, cultural events, MICE conference awards, and hospitality sector recognition programs in Bangkok and beyond."
      assign auto_local_note = 'Thailand shipments typically arrive in 5-8 business days via DHL or FedEx. Thai Customs may apply import duties and VAT on incoming goods. We provide full commercial documentation for smooth customs processing.'
    when 'trophies-to-singapore', 'custom-trophies-singapore'
      assign auto_country = 'Singapore'
      assign auto_country_code = 'SG'
      assign auto_currency = 'SGD'
      assign auto_flag = '🇸🇬'
      assign auto_shipping_days = '4-6 business days via DHL/FedEx from India'
      assign auto_areas = 'Little India (Serangoon), Marina Bay, Jurong, Changi, Tampines, Woodlands, Queenstown, Toa Payoh, Ang Mo Kio'
      assign auto_popular_occasions = 'Deepavali celebrations in Little India, Indian community association annual gala awards, corporate recognition events for Indian-led IT companies, Hindu Endowment Board temple events, cricket club trophies'
      assign auto_key_buyers = 'Singapore Indian Development Association (SINDA), Singapore Indian Fine Arts Society, Hindu Endowment Board, Nalanda Centre, Indian cricket associations Singapore'
      assign auto_diaspora_note = "Singapore has a vibrant Indian community — around 350,000 Tamil, Telugu, Hindi, and Malayali speakers. Deepavali on Serangoon Road is one of Asia's grandest Indian festivals. Meru Trophy ships custom crystal, metal, and acrylic trophies to Indian community associations, corporate events, and cultural societies in Singapore."
      assign auto_local_note = "Singapore shipments arrive in 4-6 business days. Singapore generally has low import duties, and cultural or gifting items often attract minimal or zero duty. We provide full HS-code documentation for Singapore Customs clearance."
    when 'trophies-to-canada', 'custom-trophies-canada'
      assign auto_country = 'Canada'
      assign auto_country_code = 'CA'
      assign auto_currency = 'CAD'
      assign auto_flag = '🇨🇦'
      assign auto_shipping_days = '8-12 business days via DHL/FedEx from India'
      assign auto_areas = 'Toronto, Mississauga, Brampton, Vancouver, Calgary, Edmonton, Ottawa, Winnipeg, Surrey BC, Montreal'
      assign auto_popular_occasions = 'Diwali and Navratri gala events, Indian community association annual days, Punjabi cultural events, cricket club tournaments, BAPS temple events, multicultural school award ceremonies'
      assign auto_key_buyers = 'Canada India Foundation, various regional Indian associations (TAFO - Tamil Association, Gujarati Association of Ontario), BAPS Canada, Punjabi associations in Brampton, Indian cricket clubs'
      assign auto_diaspora_note = 'Canada is home to over 1.8 million people of Indian origin — the second-largest South Asian diaspora population globally. Major concentrations in Brampton, Mississauga, Toronto, and Surrey BC. Meru Trophy ships custom trophies and mementos for community cultural festivals, cricket club events, and diaspora association award programs across Canada.'
      assign auto_local_note = "Canada shipments arrive in 8-12 business days. Canadian Customs may apply duties and HST/GST on imports. We provide a commercial invoice and HS code documentation for customs clearance. The CEPA agreement between India and Canada does not currently provide duty-free status for trophy imports."
  endcase
-%}
{%- assign country = section.settings.country_name | default: auto_country | default: 'United States' -%}
{%- assign country_code = auto_country_code | default: 'US' -%}
{%- assign flag = section.settings.country_flag | default: auto_flag | default: '🌍' -%}
{%- assign currency = section.settings.local_currency | default: auto_currency | default: 'USD' -%}
{%- assign shipping_days = section.settings.shipping_days | default: auto_shipping_days | default: '10-14 business days' -%}
{%- assign key_areas = section.settings.key_cities | default: auto_areas -%}
{%- assign popular_occasions = auto_popular_occasions -%}
{%- assign key_buyers = auto_key_buyers -%}
{%- assign diaspora_note = auto_diaspora_note -%}
{%- assign local_note = auto_local_note -%}

{%- style -%}
  /* Country landing — explicit px (theme uses 62.5% root font scaling) */
  .ctry-hero {
    background: linear-gradient(135deg, #1a1e2e 0%, #242833 100%);
    padding: 90px 24px 80px;
    text-align: center;
  }
  .ctry-hero__inner { max-width: 920px; margin: 0 auto; }
  .ctry-hero__flag {
    font-size: 56px;
    line-height: 1;
    margin-bottom: 20px;
    display: block;
  }
  .ctry-hero h1,
  .ctry-hero h1.collection-hero__title {
    font-size: 46px;
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 22px;
    color: #ffffff !important;
    font-family: var(--font-heading-family, var(--font-body-family, inherit));
    letter-spacing: -0.4px;
  }
  @media (max-width: 749px) {
    .ctry-hero h1 { font-size: 30px; }
    .ctry-hero { padding: 60px 20px 56px; }
    .ctry-hero__flag { font-size: 44px; }
  }
  .ctry-hero__sub {
    font-size: 19px;
    color: rgba(255,255,255,0.88);
    max-width: 740px;
    margin: 0 auto 40px;
    line-height: 1.65;
  }
  @media (max-width: 749px) { .ctry-hero__sub { font-size: 16px; } }
  .ctry-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }
  .ctry-btn-browse,
  .ctry-btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 34px;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, transform 0.1s;
  }
  .ctry-btn-browse {
    border: 2px solid #fff;
    color: #fff;
    background: transparent;
  }
  .ctry-btn-browse:hover { background: #fff; color: #242833; }
  .ctry-btn-wa {
    background: #25D366;
    color: #fff;
    border: 2px solid #25D366;
  }
  .ctry-btn-wa:hover { background: #1ebe5b; border-color: #1ebe5b; color: #fff; }
  .ctry-btn-wa svg { width: 22px; height: 22px; fill: currentColor; }
  .ctry-btn-browse:active,
  .ctry-btn-wa:active { transform: scale(0.98); }

  /* Shipping info strip */
  .ctry-shipping {
    background: #f0f4f8;
    padding: 48px 24px;
  }
  .ctry-shipping__inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    text-align: center;
  }
  @media (max-width: 720px) {
    .ctry-shipping__inner { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  }
  .ctry-ship-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .ctry-ship-icon {
    width: 60px; height: 60px;
    background: #242833;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ctry-ship-icon svg { width: 28px; height: 28px; fill: #fff; }
  .ctry-ship-label { font-size: 16px; font-weight: 700; color: #242833; line-height: 1.3; }
  .ctry-ship-desc { font-size: 13px; color: #555; line-height: 1.5; }

  /* About section */
  .ctry-about {
    max-width: 880px; margin: 0 auto;
    padding: 64px 24px 24px;
    font-size: 17px; line-height: 1.75; color: #1a1a1a;
  }
  .ctry-about p { font-size: 17px; line-height: 1.75; margin-bottom: 16px; color: #2a2a2a; }
  .ctry-about h2 { font-size: 30px; font-weight: 700; margin: 0 0 20px; color: #242833; line-height: 1.25; }
  .ctry-about h3 { font-size: 22px; font-weight: 700; margin: 28px 0 12px; color: #242833; line-height: 1.3; }
  .ctry-about ul { margin: 12px 0 18px; padding-left: 24px; }
  .ctry-about ul li { font-size: 17px; line-height: 1.7; margin-bottom: 6px; color: #2a2a2a; }
  .ctry-about strong { color: #1a1a1a; font-weight: 700; }
  @media (max-width: 749px) {
    .ctry-about { padding: 44px 20px 16px; font-size: 16px; }
    .ctry-about p, .ctry-about ul li { font-size: 16px; }
    .ctry-about h2 { font-size: 24px; }
    .ctry-about h3 { font-size: 19px; }
  }

  /* Products section */
  .ctry-products { padding: 64px 24px 72px; background: #fff; }
  .ctry-section-title {
    text-align: center; font-size: 30px; font-weight: 700; margin: 0 0 36px; color: #242833; line-height: 1.25;
  }
  @media (max-width: 749px) { .ctry-section-title { font-size: 24px; margin-bottom: 28px; } .ctry-products { padding: 44px 20px 52px; } }
  .ctry-products__grid {
    max-width: 1180px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;
  }
  @media (max-width: 860px) { .ctry-products__grid { grid-template-columns: repeat(2, 1fr); } }
  .ctry-product-card {
    border: 1px solid #e8e8e8; border-radius: 10px; overflow: hidden;
    text-decoration: none; color: inherit; display: block;
    transition: box-shadow 0.2s, transform 0.15s; background: #fff;
  }
  .ctry-product-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .ctry-product-card__img { width: 100%; aspect-ratio: 1/1; object-fit: contain; background: #f7f7f7; padding: 12px; }
  .ctry-product-card__body { padding: 14px 16px 18px; }
  .ctry-product-card__title { font-size: 15px; font-weight: 600; line-height: 1.4; margin: 0 0 8px; color: #242833; }
  .ctry-product-card__price { font-size: 15px; color: #444; font-weight: 600; }
  .ctry-product-card__price s { opacity: 0.5; margin-left: 8px; font-weight: 400; }

  /* Coverage areas */
  .ctry-coverage { background: #f0f4f8; padding: 56px 24px; }
  .ctry-coverage__inner { max-width: 940px; margin: 0 auto; }
  .ctry-coverage h2 { font-size: 30px; font-weight: 700; color: #242833; margin: 0 0 12px; line-height: 1.25; }
  .ctry-coverage__areas { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
  .ctry-coverage__tag {
    background: #242833; color: #fff; border-radius: 24px;
    padding: 10px 20px; font-size: 14px; font-weight: 500;
  }
  @media (max-width: 749px) { .ctry-coverage h2 { font-size: 24px; } .ctry-coverage { padding: 44px 20px; } }

  /* FAQ section */
  .ctry-faq { padding: 64px 24px 72px; background: #fff; }
  .ctry-faq__inner { max-width: 880px; margin: 0 auto; }
  .ctry-faq__list {
    margin-top: 32px; display: flex; flex-direction: column; gap: 0;
    border: 1px solid #e0e0e0; border-radius: 10px; overflow: hidden;
  }
  .ctry-faq__item { border-bottom: 1px solid #e0e0e0; }
  .ctry-faq__item:last-child { border-bottom: none; }
  .ctry-faq__q {
    width: 100%; background: none; border: none; padding: 22px 26px; text-align: left;
    font-size: 18px; font-weight: 600; color: #242833; cursor: pointer;
    display: flex; justify-content: space-between; align-items: flex-start; gap: 14px;
    font-family: var(--font-body-family, inherit); line-height: 1.45;
  }
  .ctry-faq__q:hover { background: #fafafa; }
  .ctry-faq__q-icon {
    flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
    background: #242833; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; line-height: 1; transition: transform 0.2s; margin-top: 2px;
  }
  .ctry-faq__item.open .ctry-faq__q-icon { transform: rotate(45deg); }
  .ctry-faq__a {
    display: none; padding: 0 26px 22px 26px; font-size: 16px; color: #3a3a3a; line-height: 1.7;
  }
  .ctry-faq__item.open .ctry-faq__a { display: block; }
  @media (max-width: 749px) {
    .ctry-faq { padding: 44px 20px 52px; }
    .ctry-faq__q { font-size: 16px; padding: 18px 20px; }
    .ctry-faq__a { font-size: 15px; padding: 0 20px 18px; }
  }

  /* Contact CTA */
  .ctry-contact { background: #242833; padding: 72px 24px; text-align: center; }
  .ctry-contact__inner { max-width: 720px; margin: 0 auto; }
  .ctry-contact h2 { font-size: 32px; font-weight: 700; margin: 0 0 14px; color: #ffffff !important; line-height: 1.25; }
  .ctry-contact__sub { margin: 0 0 36px; font-size: 18px; line-height: 1.6; color: rgba(255,255,255,0.88); }
  @media (max-width: 749px) { .ctry-contact h2 { font-size: 24px; } .ctry-contact { padding: 56px 20px; } }
  .ctry-btn-wa-lg {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 18px 44px; background: #25D366; color: #fff;
    border-radius: 6px; font-size: 18px; font-weight: 700;
    text-decoration: none; transition: background 0.2s, transform 0.1s; margin-bottom: 32px;
  }
  .ctry-btn-wa-lg:hover { background: #1ebe5b; color: #fff; }
  .ctry-btn-wa-lg:active { transform: scale(0.98); }
  .ctry-btn-wa-lg svg { width: 22px; height: 22px; fill: currentColor; }
  .ctry-contact__details {
    display: flex; flex-direction: column; gap: 10px;
    font-size: 16px; color: rgba(255,255,255,0.88); line-height: 1.6;
  }
  .ctry-contact__details a { color: #fff; text-decoration: none; font-weight: 500; }
  .ctry-contact__details a:hover { text-decoration: underline; }
{%- endstyle -%}

<!-- HERO -->
