{%- comment -%} v1-2026-05-12 country landing page {%- endcomment -%}
{%- liquid
  assign handle = page.handle | default: ''
  assign auto_country = ''
  assign auto_country_code = ''
  assign auto_currency = ''
  assign auto_shipping_days = '10-14 business days'
