<script>
  (function () {
    var DATA_URL = '{{ 'brands-data.json' | asset_url }}';
    var marquee1 = document.getElementById('brands-marquee-row1');
    var marquee2 = document.getElementById('brands-marquee-row2');
    var catsHost = document.getElementById('brands-categories');
    var filtersHost = document.getElementById('brands-filters');
    var searchInput = document.getElementById('brands-search-input');
    var statTotal = document.getElementById('brands-stat-total');
    var emptyEl = document.getElementById('brands-empty');

    var STATE = { data: null, filter: 'all', query: '' };

    function esc(s) {
      return String(s || '').replace(/[&<>"']/g, function (c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c];
      });
    }

    function buildMarquees(categories) {
      var featured = [];
      var all = [];
      categories.forEach(function (cat) {
        cat.brands.forEach(function (b) {
          all.push(b.name);
          if (b.featured) featured.push(b.name);
        });
      });
      if (featured.length < 12) featured = all.slice();
      // shuffle for visual variety
      function shuf(arr) {
        var a = arr.slice();
        for (var i = a.length - 1; i > 0; i--) {
          var j = Math.floor(Math.random() * (i + 1));
          var t = a[i]; a[i] = a[j]; a[j] = t;
        }
        return a;
      }
      var row1 = shuf(featured);
      var row2 = shuf(all).slice(0, 30);
      function buildHtml(names) {
        var html = '';
        var doubled = names.concat(names);
        doubled.forEach(function (n) {
          html += '<span class="brands-marquee__chip">' + esc(n) + '</span>';
        });
        return html;
      }
      marquee1.innerHTML = buildHtml(row1);
      marquee2.innerHTML = buildHtml(row2);
    }

    function buildFilters(categories) {
      categories.forEach(function (cat) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'brands-filter';
        btn.dataset.cat = cat.slug;
        btn.setAttribute('aria-pressed', 'false');
        btn.textContent = cat.name + ' (' + cat.brands.length + ')';
        filtersHost.appendChild(btn);
      });
      filtersHost.addEventListener('click', function (e) {
        var b = e.target.closest('.brands-filter');
        if (!b) return;
        STATE.filter = b.dataset.cat;
        filtersHost.querySelectorAll('.brands-filter').forEach(function (x) {
          x.setAttribute('aria-pressed', x === b ? 'true' : 'false');
        });
        render();
      });
    }

    function brandMatches(b) {
      if (!STATE.query) return true;
      return b.name.toLowerCase().indexOf(STATE.query) !== -1;
    }

    function render() {
      catsHost.innerHTML = '';
      var totalShown = 0;
      STATE.data.categories.forEach(function (cat) {
        if (STATE.filter !== 'all' && STATE.filter !== cat.slug) return;
        var visible = cat.brands.filter(brandMatches);
        if (!visible.length) return;
        var html = '<section class="brands-category" data-slug="' + esc(cat.slug) + '">' +
          '<header class="brands-category__head">' +
            '<h2 class="brands-category__title">' + esc(cat.name) +
              '<span class="brands-category__count">' + visible.length + '</span>' +
            '</h2>' +
          '</header>' +
          '<p class="brands-category__desc">' + esc(cat.description || '') + '</p>' +
          '<div class="brands-grid">' +
            visible.map(function (b) {
              var cls = 'brand-card' + (b.featured ? ' brand-card--featured' : '');
              var inner = '<span class="brand-card__name">' + esc(b.name) + '</span>';
              if (b.website) {
                return '<a class="' + cls + '" href="' + esc(b.website) + '" target="_blank" rel="noopener">' + inner + '</a>';
              }
              return '<div class="' + cls + '" tabindex="0">' + inner + '</div>';
            }).join('') +
          '</div>' +
        '</section>';
        catsHost.insertAdjacentHTML('beforeend', html);
        totalShown += visible.length;
      });
      emptyEl.hidden = totalShown > 0;
      observeCards();
    }

    function observeCards() {
      var cards = catsHost.querySelectorAll('.brand-card');
      if (!('IntersectionObserver' in window)) {
        cards.forEach(function (c) { c.classList.add('is-visible'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e, i) {
          if (e.isIntersecting) {
            setTimeout(function () { e.target.classList.add('is-visible'); }, (i % 12) * 35);
            io.unobserve(e.target);
          }
        });
      }, { rootMargin: '0px 0px -40px 0px', threshold: 0.05 });
      cards.forEach(function (c) { io.observe(c); });
    }

    searchInput.addEventListener('input', function () {
      STATE.query = searchInput.value.trim().toLowerCase();
      render();
    });

    fetch(DATA_URL).then(function (r) { return r.json(); }).then(function (data) {
      STATE.data = data;
      var total = 0;
      data.categories.forEach(function (c) { total += c.brands.length; });
      if (statTotal) statTotal.textContent = total + '+';
      buildMarquees(data.categories);
      buildFilters(data.categories);
      render();
    }).catch(function () {
      emptyEl.hidden = false;
      emptyEl.textContent = 'Brands list could not be loaded.';
    });
  })();
</script>

