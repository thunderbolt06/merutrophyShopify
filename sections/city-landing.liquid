{% assign city = section.settings.city_name | default: "Bangalore" %}
{% assign city_local = section.settings.city_name_local | default: city %}
{% assign city_state = section.settings.city_state | default: "Karnataka" %}
{% assign delivery_areas = section.settings.delivery_areas | default: "Whitefield, Koramangala, Indiranagar, Electronic City, HSR Layout, BTM Layout, Marathahalli, Hebbal" %}
{% assign latitude = section.settings.latitude | default: "12.9716" %}
{% assign longitude = section.settings.longitude | default: "77.5946" %}

{%- style -%}
  .city-hero {
    background-color: #242833;
    color: #ffffff;
    padding: 80px 20px 70px;
    text-align: center;
  }
  .city-hero__inner {
    max-width: 860px;
    margin: 0 auto;
  }
  .city-hero h1 {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 800;
    line-height: 1.25;
    margin: 0 0 20px;
    font-family: var(--font-heading-family, var(--font-body-family, inherit));
  }
  .city-hero__sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    opacity: 0.85;
    max-width: 680px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }
  .city-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }
  .btn-browse {
    display: inline-block;
    padding: 14px 32px;
    border: 2px solid #ffffff;
    color: #ffffff;
    background: transparent;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .btn-browse:hover {
    background: #ffffff;
    color: #242833;
  }
  .btn-whatsapp {
    display: inline-block;
    padding: 14px 32px;
    background: #25D366;
    color: #ffffff;
    border: 2px solid #25D366;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-whatsapp:hover {
    background: #1ebe5b;
    border-color: #1ebe5b;
  }
  .btn-whatsapp svg,
  .btn-whatsapp-lg svg {
    width: 20px;
    height: 20px;
    vertical-align: middle;
    margin-right: 6px;
    fill: currentColor;
  }

  /* Why Choose Us Strip */
  .city-why {
    background: #f7f7f7;
    padding: 44px 20px;
  }
  .city-why__grid {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }
  @media (max-width: 720px) {
    .city-why__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .city-why__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .city-why__icon {
    width: 52px;
    height: 52px;
    background: #242833;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .city-why__icon svg {
    width: 26px;
    height: 26px;
    fill: #ffffff;
  }
  .city-why__label {
    font-size: 0.95rem;
    font-weight: 700;
    color: #242833;
    line-height: 1.3;
  }
  .city-why__desc {
    font-size: 0.82rem;
    color: #555;
    line-height: 1.4;
  }

  /* Local Description */
  .city-about {
    max-width: 820px;
    margin: 0 auto;
    padding: 52px 20px 20px;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-foreground, #333);
  }
  .city-about h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #242833;
  }

  /* Products Section */
  .city-products {
    padding: 48px 20px 56px;
    background: #fff;
  }
  .city-section-title {
    text-align: center;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 32px;
    color: #242833;
  }
  .city-products__grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  @media (max-width: 860px) {
    .city-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 440px) {
    .city-products__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
  .city-product-card {
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: box-shadow 0.2s;
    background: #fff;
  }
  .city-product-card:hover {
    box-shadow: 0 4px 18px rgba(0,0,0,0.1);
  }
  .city-product-card__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    background: #f7f7f7;
    padding: 10px;
  }
  .city-product-card__body {
    padding: 12px 14px 16px;
  }
  .city-product-card__title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 6px;
    color: #242833;
  }
  .city-product-card__price {
    font-size: 0.88rem;
    color: #666;
  }
  .city-product-card__price s {
    opacity: 0.55;
    margin-left: 6px;
  }

  /* Delivery Areas */
  .city-delivery {
    background: #f0f4f8;
    padding: 48px 20px;
  }
  .city-delivery__inner {
    max-width: 860px;
    margin: 0 auto;
  }
  .city-delivery__areas {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }
  .city-delivery__tag {
    background: #242833;
    color: #fff;
    border-radius: 20px;
    padding: 6px 16px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* FAQ Section */
  .city-faq {
    padding: 56px 20px 64px;
    background: #fff;
  }
  .city-faq__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .city-faq__list {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
  }
  .city-faq__item {
    border-bottom: 1px solid #e0e0e0;
  }
  .city-faq__item:last-child {
    border-bottom: none;
  }
  .city-faq__q {
    width: 100%;
    background: none;
    border: none;
    padding: 20px 24px;
    text-align: left;
    font-size: 1rem;
    font-weight: 600;
    color: #242833;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--font-body-family, inherit);
    line-height: 1.4;
  }
  .city-faq__q:hover {
    background: #fafafa;
  }
  .city-faq__q-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #242833;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    line-height: 1;
    transition: transform 0.2s;
    margin-top: 2px;
  }
  .city-faq__item.open .city-faq__q-icon {
    transform: rotate(45deg);
  }
  .city-faq__a {
    display: none;
    padding: 0 24px 20px 24px;
    font-size: 0.95rem;
    color: #444;
    line-height: 1.7;
  }
  .city-faq__item.open .city-faq__a {
    display: block;
  }

  /* Contact Section */
  .city-contact {
    background: #242833;
    color: #fff;
    padding: 56px 20px;
    text-align: center;
  }
  .city-contact__inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .city-contact h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .city-contact__sub {
    opacity: 0.8;
    margin-bottom: 32px;
    font-size: 1rem;
    line-height: 1.6;
  }
  .btn-whatsapp-lg {
    display: inline-block;
    padding: 16px 40px;
    background: #25D366;
    color: #ffffff;
    border-radius: 4px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
    margin-bottom: 28px;
  }
  .btn-whatsapp-lg:hover {
    background: #1ebe5b;
  }
  .city-contact__details {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 0.95rem;
    opacity: 0.85;
    line-height: 1.6;
  }
  .city-contact__details a {
    color: #ffffff;
    text-decoration: none;
  }
  .city-contact__details a:hover {
    text-decoration: underline;
  }
{%- endstyle -%}

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="city-hero">
  <div class="city-hero__inner">
    <h1>{{ section.settings.hero_heading }}</h1>
    {%- if section.settings.hero_subheading != blank -%}
      <p class="city-hero__sub">{{ section.settings.hero_subheading }}</p>
    {%- endif -%}
    <div class="city-hero__ctas">
      <a href="/collections/all" class="btn-browse">Browse Trophies</a>
      <a href="https://wa.me/+919480150888?text=Hi" class="btn-whatsapp" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp Us
      </a>
