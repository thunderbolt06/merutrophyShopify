     LOCAL SEO PARAGRAPH
     ============================================================ -->
{%- if section.settings.local_seo_paragraph != blank -%}
<div class="city-about">
  <h2>Custom Trophy Makers in {{ city }}, {{ city_state }}</h2>
  {%- capture rm_city_content -%}
    {{ section.settings.local_seo_paragraph }}
